{
  "_predictor": {
    "traces": [],
    "train": [],
    "demos": [],
    "signature": {
      "instructions": "Route the conversation state and emit structured JSON-compatible fields.",
      "fields": [
        {
          "prefix": "User Message:",
          "description": "${user_message}"
        },
        {
          "prefix": "Conversation Summary:",
          "description": "${conversation_summary}"
        },
        {
          "prefix": "Current Mode:",
          "description": "${current_mode}"
        },
        {
          "prefix": "Last Tool Result:",
          "description": "${last_tool_result}"
        },
        {
          "prefix": "Last Assistant Message:",
          "description": "${last_assistant_message}"
        },
        {
          "prefix": "Memories:",
          "description": "${memories}"
        },
        {
          "prefix": "Next Node:",
          "description": "${next_node}"
        },
        {
          "prefix": "Intent:",
          "description": "${intent}"
        },
        {
          "prefix": "Confidence:",
          "description": "${confidence}"
        },
        {
          "prefix": "Needs Retrieval:",
          "description": "${needs_retrieval}"
        },
        {
          "prefix": "State Update:",
          "description": "${state_update}"
        },
        {
          "prefix": "Reason:",
          "description": "${reason}"
        }
      ]
    },
    "lm": null
  },
  "metadata": {
    "dependency_versions": {
      "python": "3.13",
      "dspy": "2.6.27",
      "cloudpickle": "3.1"
    }
  }
}