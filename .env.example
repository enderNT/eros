# =========================
# Core app
# =========================
#APP_ENV=production
APP_ENV=development
APP_NAME=eros-assistant-template
APP_HOST=0.0.0.0
APP_PORT=3000
APP_LOG_TO_CONSOLE=true
APP_LOG_TO_FILE=true
APP_LOG_DIR=./var/log/stateful-assistant
APP_LOG_FILE=app.log
# APP_LOG_MAX_FILES=
# APP_LOG_MAX_LINES=
APP_LOG_MAX_FILES=3
APP_LOG_MAX_LINES=200
APP_INSTANCE_ID=
APP_CONTAINER_NAME=
APP_CONTAINER_ID=
APP_HOST_NAME=
APP_DEFAULT_LOCALE=es-MX
APP_DEFAULT_TIMEZONE=America/Mexico_City
APP_SHUTDOWN_GRACE_MS=5000

# =========================
# LLM
# =========================
LLM_PROVIDER=openai_compatible
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-5-mini
LLM_TIMEOUT_MS=30000
LLM_TEMPERATURE=

# =========================
# Routing / prompt budget
# =========================
ROUTER_CONFIDENCE_THRESHOLD=0.62
ROUTER_KNOWLEDGE_THRESHOLD=0.58
PROMPT_MEMORY_MAX_ITEMS=3
PROMPT_MEMORY_BUDGET_CHARS=1200
PROMPT_RECENT_TURNS_LIMIT=3
PROMPT_SUMMARIZE_ON_OVERFLOW=true

# =========================
# Short-term state
# =========================
STATE_SUMMARY_REFRESH_TURN_THRESHOLD=4
STATE_SUMMARY_REFRESH_CHAR_THRESHOLD=900

# =========================
# Long-term memory component
# =========================
MEMORY_PROVIDER=in_memory
MEMORY_ENABLED=true
MEMORY_AGENT_ID=default-assistant
MEMORY_TOP_K=5
MEMORY_SCORE_THRESHOLD=0.0
MEM0_BASE_URL=
MEM0_API_KEY=
MEM0_AUTH_MODE=auto
MEM0_ORG_ID=
MEM0_PROJECT_ID=
MEM0_SEARCH_PATH=/v1/memories/search
MEM0_ADD_PATH=/v1/memories

# =========================
# Clinic domain config
# =========================
CLINIC_CONFIG_PATH=./config/clinic.json
CLINIC_BOOKING_URL=https://calendly.com/gayagocr/new-meeting

# =========================
# Channel adapter
# =========================
CHANNEL_PROVIDER=none
CHANNEL_REPLY_ENABLED=false
CHATWOOT_BASE_URL=
CHATWOOT_API_ACCESS_TOKEN=
CHATWOOT_ACCOUNT_ID=

# =========================
# Tracing / observability
# =========================
TRACE_BACKEND=in_memory
TRACE_APP_KEY=stateful-assistant
TRACE_BATCH_SIZE=25
TRACE_FLUSH_INTERVAL_MS=1000
TRACE_PROJECTORS_ENABLED=true
TRACE_STORE_RAW_RECALL=true
TRACE_STORE_PROMPT_DIGEST=true
TRACE_FLUSH_TIMEOUT_MS=5000
TRACE_RECENT_LIMIT=200
TRACE_PROJECTOR_VERSION=v1
TRACE_POSTGRES_URL=
TRACE_POSTGRES_SCHEMA=tracing
TRACE_POSTGRES_CONNECT_TIMEOUT_MS=3000
TRACE_POSTGRES_QUERY_TIMEOUT_MS=5000
TRACE_POSTGRES_HEALTH_TIMEOUT_MS=2000

# =========================
# DSPy bridge
# =========================
DSPY_ENABLED=false
DSPY_SERVICE_URL=http://dspy-service:8001
DSPY_TIMEOUT_MS=4000
DSPY_RETRY_COUNT=1
DSPY_MODEL=gpt-4o-mini
DSPY_API_BASE=
DSPY_API_KEY=
DSPY_ARTIFACTS_DIR=./dspy_service/artifacts
DSPY_DATASETS_DIR=./dspy_service/datasets
DSPY_OPTIMIZATION_ENABLED=false

# =========================
# Qdrant retrieval
# =========================
QDRANT_ENABLED=false
QDRANT_SIMULATE=true
QDRANT_BASE_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=clinic_knowledge
QDRANT_TIMEOUT_MS=10000
QDRANT_TOP_K=5
QDRANT_VECTOR_SIZE=1536
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

NGROK_PORT=3000

# =========================
# Docker / container runtime
# =========================
DOCKER_APP_PORT=3000
DOCKER_DSPY_PORT=8001
