APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

LLM_PROVIDER=openai_compatible
LLM_API_KEY=sk-...
LLM_BASE_URL=
LLM_MODEL=gpt-5-mini
LLM_TIMEOUT_SECONDS=30
LLM_TEMPERATURE=0.1

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=
OPENAI_TIMEOUT_SECONDS=

CLINIC_CONFIG_PATH=config/clinic.json

MEMORY_BACKEND=in_memory
MEMORY_POSTGRES_DSN=
MEMORY_POSTGRES_INDEX_DIMS=1536
MEMORY_POSTGRES_SETUP_ON_START=true

TRACE_BACKEND=in_memory
TRACE_POSTGRES_DSN=
TRACE_POSTGRES_SETUP_ON_START=true
TRACE_BATCH_SIZE=25
TRACE_FLUSH_INTERVAL_SECONDS=1.0
TRACE_PROJECTORS_ENABLED=true
TRACE_APP_KEY=clinica-assistant

QDRANT_ENABLED=false
QDRANT_SIMULATE=true
QDRANT_BASE_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=clinic_knowledge
QDRANT_TIMEOUT_SECONDS=10
QDRANT_TOP_K=5
QDRANT_VECTOR_SIZE=8

CHATWOOT_REPLY_ENABLED=false
CHATWOOT_API_BASE_URL=
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=

NGROK_AUTHTOKEN=
NGROK_DOMAIN=
